/* The following values are being overridden by the website */
/* by being passed in from index.njk:                       */
/* 1. personName (for inclusion in header.njk)              */                                           
/* 2. highestDegree (for inclusion in header.njk)           */
/* 3. websiteTitle (for inclusion in header.njk)            */                                         
/* 4. websiteVersion (for inclusion in footer.njk)          */ 

{% set headerPersonName %}
  {% block personName %}Default Person Name{% endblock %}
{% endset %}
{% set headerHighestDegree %}
  {% block highestDegree %}Default Highest Degree{% endblock %}
{% endset %}
{% set headerWebsiteTitle %}
  {% block websiteTitle %}Default Website Title{% endblock %}
{% endset %}
{% set footerWebsiteVersion %}
  {% block websiteVersion %}Default WebsiteVersion{% endblock %}
{% endset %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ headerWebsiteTitle }}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="outer-wrapper">
        {% include "partials/header.html" %}

        <div class="middle-wrapper">
                {% include "partials/sidebar.html" %}

                {# This is the ONLY place content enters the shell #}
                <main id="content-panel-container">
                    {% block main %}{% endblock %}
                </main>   
        </div>

        {% include "partials/footer.html" %}

        <!-- Spinner overlay -->
        <div id="spinner" class="spinner-overlay"></div>
        <div id="menu-overlay"></div> 
    </div>    
    <section class="pdf-viewer-container">
        <nav class="viewer-toolbar">
            <span class="viewer-title">Document</span>
            <div class="btn-group">
                <button class="btn-close-viewer">Close [X]</button>
            </div>
        </nav>
        <iframe src="" title="PDF Preview"></iframe>
    </section>
    <script type="module" src="/assets/js/controllerNavHandler.js"></script>
</body>
</html>