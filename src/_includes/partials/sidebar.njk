<nav id="navig-rail-container" aria-label="Main Category Navigation">
  <ul class="navig-rail-container__list">
    {% for menuItem in fetchNavigationTree %}
    <pre>{{ menuItem | log }}</pre>
    <li><button data-category="{{ menuItem.slug }}">
      {{ menuItem.cleanedTitle }}
    </button></li>
    {% endfor %}
  </ul>
</nav>


