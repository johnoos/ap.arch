{# Set defaults if the website doesn't provide them #}
{% set personName = personName or "Default Name" %}
{% set highestDegree = highestDegree or "" %}
{% set websiteTitle = websiteTitle or "Default Title" %}
{% set websiteVersion = websiteVersion or "V1.0" %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ websiteTitle }}</title>
    <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
    <div class="outer-wrapper">
        {% include "partials/header.njk" %}

        <div class="middle-wrapper">
            {% include "partials/sidebar.njk" %}   
            <main id="content-panel-container">
                {% block main %}{% endblock %}
            </main>   
        </div>

        {% include "partials/footer.njk" %}
    </div>    
    <script type="module" src="/assets/js/arch/controllerNavHandler.js"></script>
</body>
</html>